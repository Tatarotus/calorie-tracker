NVIDIA_API_KEY=

FATSECRET_CLIENT_ID=
FATSECRET_CLIENT_SECRET=
FATSECRET_SCOPE=basic

# Brazil/Portuguese are configured for future localization support.
# FatSecret marks localization as premium, so leave this false on Basic.
FATSECRET_REGION=BR
FATSECRET_LANGUAGE=pt
FATSECRET_USE_LOCALIZATION=false
